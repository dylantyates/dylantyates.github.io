---
import BaseLayout from "../layouts/base-layout.astro";

// Progress for each "Currently" item (0–100). Set these to reflect progress on that task.
const currentlyProgress = {
  building: 100,
  listening: 100,
  reading: 100,
  watching: 100,
};
---

<BaseLayout
  title="Dylan Yates"
  description="Dylan Yates — personal presence, projects, and links."
>
  <main class="mx-auto flex min-h-screen max-w-2xl flex-col gap-4 px-6 py-4">
    <header class="pt-4" data-animate="hero">
      <h1 class="mb-2 text-3xl font-bold tracking-tight text-zinc-100">
        Dylan Yates
      </h1>
      <p class="text-lg text-zinc-400">Houston, Texas</p>
    </header>
    <section class="py-6" data-animate="reveal" data-reveal-stagger>
      <dl class="m-0 flex flex-col gap-6 text-sm text-zinc-400">
        <div>
          <div
            class="mb-2 flex flex-col gap-1"
            role="progressbar"
            aria-valuenow={currentlyProgress.building}
            aria-valuemin={0}
            aria-valuemax={100}
            aria-label="Progress for Building"
          >
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-zinc-800">
              <div
                class="h-full min-w-0.5 rounded-full bg-sky-300 transition-all duration-300 ease-in-out motion-reduce:transition-none"
                style={`width: ${currentlyProgress.building}%`}
              >
              </div>
            </div>
          </div>
          <dt class="mb-1.5 font-semibold text-zinc-100">What I Like To Do</dt>
          <dd class="m-0">
            Music, doggos, hiking, camping, kayaking, and coding.
          </dd>
        </div>
        <div>
          <div
            class="mb-2 flex flex-col gap-1"
            role="progressbar"
            aria-valuenow={currentlyProgress.listening}
            aria-valuemin={0}
            aria-valuemax={100}
            aria-label="Progress for Listening"
          >
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-zinc-800">
              <div
                class="h-full min-w-0.5 rounded-full bg-emerald-300 transition-all duration-300 ease-in-out motion-reduce:transition-none"
                style={`width: ${currentlyProgress.listening}%`}
              >
              </div>
            </div>
          </div>
          <dt class="mb-1.5 font-semibold text-zinc-100">Where I Work</dt>
          <dd class="m-0">
            Senior Software Engineer at <a
              href="https://blinds.com"
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-sky-300 transition-colors hover:text-sky-200"
              >Blinds.com</a
            >/<a
              href="https://homedepot.com"
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-sky-300 transition-colors hover:text-sky-200"
              >The Home Depot</a
            >
          </dd>
        </div>
        <div>
          <div
            class="mb-2 flex flex-col gap-1"
            role="progressbar"
            aria-valuenow={currentlyProgress.watching}
            aria-valuemin={0}
            aria-valuemax={100}
            aria-label="Progress for Watching"
          >
            <div class="h-1.5 w-full overflow-hidden rounded-full bg-zinc-800">
              <div
                class="h-full min-w-0.5 rounded-full bg-purple-300 transition-all duration-300 ease-in-out motion-reduce:transition-none"
                style={`width: ${currentlyProgress.watching}%`}
              >
              </div>
            </div>
          </div>
          <dt class="mb-1.5 font-semibold text-zinc-100">
            Where I Went To School
          </dt>
          <dd class="m-0">
            Bachelor of Science in Economics from <a
              href="https://tamu.edu"
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-sky-300 transition-colors hover:text-sky-200"
              >Texas A&amp;M University - College Station</a
            >
          </dd>
        </div>
      </dl>
    </section>

    <section class="py-6" data-animate="reveal" data-reveal-stagger>
      <h2 class="mb-4 text-lg font-bold uppercase tracking-wider text-white">
        Projects
      </h2>
      <ul class="m-0 flex list-none flex-col gap-3 p-0 text-sm text-zinc-400">
        <li>
          <a
            href="/ai-process-visualization/"
            class="box-border inline-block rounded-md bg-indigo-600 px-4 py-2 font-medium text-white transition-colors hover:bg-indigo-500 hover:text-white"
            data-animate="link"
          >
            AI process visualization
          </a>
          <p class="m-0 mt-1 max-w-prose text-sm">
            Interactive diagram of how an AI assistant turns your question into
            an answer.
          </p>
        </li>
      </ul>
    </section>

    <section class="py-6" data-animate="reveal" data-reveal-stagger>
      <h2
        class="mb-4 text-xs font-semibold uppercase tracking-wider text-zinc-400"
      >
        Elsewhere
      </h2>
      <ul class="m-0 flex flex-wrap gap-4 p-0 font-mono text-sm">
        <li>
          <a
            href="https://github.com/dylantyates"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block rounded-md px-2 py-1 text-sky-300 transition-colors hover:bg-zinc-900 hover:text-sky-200"
            data-animate="link"
          >
            GitHub
          </a>
        </li>
        <li>
          <a
            href="https://www.linkedin.com/in/dylanyates/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block rounded-md px-2 py-1 text-sky-300 transition-colors hover:bg-zinc-900 hover:text-sky-200"
            data-animate="link"
          >
            LinkedIn
          </a>
        </li>
      </ul>
    </section>

    <footer class="mt-auto pt-12" data-animate="reveal" data-reveal-stagger>
      <p class="text-sm text-zinc-400">
        &copy; {new Date().getFullYear()} Dylan Yates. All rights reserved.
      </p>
    </footer>
  </main>
</BaseLayout>
